# Port to run the server on
PORT=5000

# SQLite database file name (relative to backend root)
DB_FILE=database.sqlite

# Secret key used for signing JWT authentication tokens
JWT_SECRET=your_jwt_secret_key_here

# Base URL of the React frontend application (for links in emails/PDFs)
FRONTEND_URL=http://localhost:5173

# --- SMTP Transactional Email Configuration ---
# Leaving SMTP_USER and SMTP_PASS empty will automatically generate
# an Ethereal development mailer account on startup for testing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Instituto Superior del Norte LMS <noreply@institutosuperiordelnorte.co>"
